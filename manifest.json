{
  "manifest_version": 3,
  "name": "Hard Refresh + Clear Cache",
  "version": "1.0.0",
  "description": "One-click hard refresh on current tab and clear cache.",
  "permissions": ["tabs", "browsingData"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "TabZap",
    "default_icon": {
      "16": "icons/16.png",
      "32": "icons/32.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  },
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
"background.js"
  }
}
